# NVIDIA Build API — used by the scraper pipeline for LLM-assisted extraction.
# Get a key at https://build.nvidia.com — free tier available.
# DO NOT commit your real key. .env is gitignored.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the LLM used for extraction. Default: meta/llama-3.3-70b-instruct
# NVIDIA_EXTRACTION_MODEL=meta/llama-3.3-70b-instruct

# Optional: override base URL (OpenAI-compatible). Default: https://integrate.api.nvidia.com/v1
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
